// DreamPlanner Database Schema
// Prisma ORM with PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id          String   @id @default(uuid())
  firebaseUid String   @unique @map("firebase_uid")
  email       String   @unique
  username    String?
  avatar      String?
  timezone    String   @default("Europe/Paris")

  // Location
  country String?
  city    String?

  // Language preference
  preferredLanguage String? @default("fr") @map("preferred_language")

  // Subscription
  subscription     String    @default("free") // free, premium, pro
  subscriptionEnds DateTime? @map("subscription_ends")

  // Work Schedule (JSON)
  // { workDays: [1,2,3,4,5], startTime: "09:00", endTime: "18:00" }
  workSchedule Json? @map("work_schedule")

  // Notification Preferences (JSON)
  // { reminders: true, motivation: true, dndStart: 22, dndEnd: 7 }
  notificationPrefs Json? @map("notification_prefs")

  // App Preferences (JSON)
  // { theme: "light", language: "fr", reminderMinutesBefore: 15 }
  appPrefs Json? @map("app_prefs")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  dreams              Dream[]
  conversations       Conversation[]
  notifications       Notification[]
  fcmTokens           FcmToken[]
  profile             UserProfile?
  xpTransactions      XpTransaction[]
  achievements        UserAchievement[]
  friendshipsAsUser1  Friendship[]        @relation("User1")
  friendshipsAsUser2  Friendship[]        @relation("User2")
  following           Follow[]            @relation("Follower")
  followers           Follow[]            @relation("Following")
  buddyPairings1      DreamBuddy[]        @relation("User1")
  buddyPairings2      DreamBuddy[]        @relation("User2")
  circleMembers       CircleMember[]
  circlePosts         CirclePost[]
  circlePostReactions CirclePostReaction[]
  activityFeed        ActivityFeed[]      @relation("UserFeed")
  activityAsActor     ActivityFeed[]      @relation("Actor")
  commitments         PublicCommitment[]
  witnesses           CommitmentWitness[]

  @@map("users")
}

model FcmToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String   // ios, android
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("fcm_tokens")
}

// ============================================
// DREAMS & GOALS
// ============================================

model Dream {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String    @db.Text
  category    String?   // career, health, education, personal, finance, travel, creativity, wellness
  targetDate  DateTime? @map("target_date")
  priority    Int       @default(1) // 1-5

  status      String    @default("active") // active, completed, paused, archived
  completedAt DateTime? @map("completed_at")

  // AI Analysis (JSON)
  // { feasibility: "high", estimatedDuration: "6 months", tips: [], obstacles: [] }
  aiAnalysis Json? @map("ai_analysis")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  goals         Goal[]
  conversations Conversation[]

  @@index([userId, status])
  @@map("dreams")
}

model Goal {
  id          String   @id @default(uuid())
  dreamId     String   @map("dream_id")
  dream       Dream    @relation(fields: [dreamId], references: [id], onDelete: Cascade)

  title       String
  description String?  @db.Text
  order       Int      // Sequence order within dream

  // Scheduling
  estimatedMinutes Int?      @map("estimated_minutes")
  scheduledStart   DateTime? @map("scheduled_start")
  scheduledEnd     DateTime? @map("scheduled_end")

  status      String    @default("pending") // pending, in_progress, completed, skipped
  completedAt DateTime? @map("completed_at")

  // Reminders
  reminderEnabled Boolean   @default(true) @map("reminder_enabled")
  reminderTime    DateTime? @map("reminder_time")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tasks Task[]

  @@index([dreamId, order])
  @@map("goals")
}

model Task {
  id          String   @id @default(uuid())
  goalId      String   @map("goal_id")
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)

  title          String
  description    String?
  order          Int      // Sequence order within goal
  estimatedMinutes Int? @map("estimated_minutes")

  // Scheduling
  scheduledDate DateTime? @map("scheduled_date")
  scheduledTime String?   @map("scheduled_time") // "HH:mm"
  durationMins  Int?      @map("duration_mins")

  // Recurrence (JSON)
  // { type: "daily" | "weekly", days: [1,3,5], until: "2024-12-31" }
  recurrence Json?

  status      String    @default("pending") // pending, completed, skipped
  completedAt DateTime? @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([goalId, scheduledDate])
  @@map("tasks")
}

// ============================================
// CONVERSATIONS & MESSAGES
// ============================================

model Conversation {
  id      String  @id @default(uuid())
  userId  String  @map("user_id")
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  dreamId String? @map("dream_id")
  dream   Dream?  @relation(fields: [dreamId], references: [id], onDelete: SetNull)

  // Conversation type
  type String // dream_creation, planning, check_in, adjustment, general

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  messages Message[]

  @@index([userId, createdAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    String // user, assistant, system
  content String @db.Text

  // Metadata (JSON)
  // For assistant: { tokensUsed: 150, model: "gpt-4" }
  // For user: { extractedIntent: "create_dream" }
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Notification content
  type  String // reminder, motivation, progress, achievement, check_in
  title String
  body  String

  // Deep link data (JSON)
  // { screen: "dream_detail", params: { dreamId: "xxx" } }
  data Json?

  // Scheduling
  scheduledFor DateTime  @map("scheduled_for")
  sentAt       DateTime? @map("sent_at")
  readAt       DateTime? @map("read_at")

  status String @default("pending") // pending, sent, failed, cancelled

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, scheduledFor])
  @@index([status, scheduledFor])
  @@map("notifications")
}

// ============================================
// GAMIFICATION SYSTEM (Strava-like)
// ============================================

model UserProfile {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // RPG Attributes (0-100)
  attributeDiscipline Int @default(0) @map("attribute_discipline")
  attributeLearning   Int @default(0) @map("attribute_learning")
  attributeWellbeing  Int @default(0) @map("attribute_wellbeing")
  attributeCareer     Int @default(0) @map("attribute_career")
  attributeCreativity Int @default(0) @map("attribute_creativity")

  // Gamification
  totalXp        Int @default(0) @map("total_xp")
  currentLevel   Int @default(1) @map("current_level")
  xpToNextLevel  Int @default(100) @map("xp_to_next_level")
  influenceScore Int @default(0) @map("influence_score")

  // Streak tracking
  currentStreak        Int @default(0) @map("current_streak")
  longestStreak        Int @default(0) @map("longest_streak")
  streakInsuranceCount Int @default(0) @map("streak_insurance_count")

  // Customization
  title       String  @default("Rêveur")
  customTheme String? @map("custom_theme")

  // Privacy settings (JSON)
  privacySettings Json @default("{}") @map("privacy_settings")

  // Biography
  bio        String? @db.Text
  location   String?
  websiteUrl String? @map("website_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_profiles")
}

model XpTransaction {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount      Int
  source      String // task_completed, milestone, buddy_help, etc.
  sourceId    String? @map("source_id")
  multiplier  Float   @default(1.0)

  // Attribute impact (JSON)
  attributeImpact Json? @map("attribute_impact")

  description String
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("xp_transactions")
}

model Achievement {
  id          String @id @default(uuid())
  key         String @unique
  name        String
  description String
  icon        String
  category    String // streak, milestone, social, special
  tier        String // bronze, silver, gold, platinum
  xpReward    Int    @map("xp_reward")

  // Unlock criteria (JSON)
  criteria Json

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String      @map("achievement_id")
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  unlockedAt DateTime @default(now()) @map("unlocked_at")
  progress   Int      @default(100)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model Leaderboard {
  id       String @id @default(uuid())
  scope    String // global, friends, local, category
  category String? // career, health, etc.
  period   String // daily, weekly, monthly, all_time

  // Geographic scope
  country String?
  city    String?

  // Rankings snapshot (JSON array)
  rankings Json

  calculatedAt DateTime @default(now()) @map("calculated_at")
  expiresAt    DateTime @map("expires_at")

  @@unique([scope, category, period, country, city, calculatedAt])
  @@index([scope, period, expiresAt])
  @@map("leaderboards")
}

// ============================================
// SOCIAL FEATURES
// ============================================

model Friendship {
  id      String @id @default(uuid())
  user1Id String @map("user1_id")
  user1   User   @relation("User1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id String @map("user2_id")
  user2   User   @relation("User2", fields: [user2Id], references: [id], onDelete: Cascade)

  status String // pending, accepted, rejected

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@map("friendships")
}

model Follow {
  id          String @id @default(uuid())
  followerId  String @map("follower_id")
  follower    User   @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String @map("following_id")
  following   User   @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model DreamBuddy {
  id      String @id @default(uuid())
  user1Id String @map("user1_id")
  user1   User   @relation("User1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id String @map("user2_id")
  user2   User   @relation("User2", fields: [user2Id], references: [id], onDelete: Cascade)

  status String @default("active") // active, paused, ended

  // Accountability settings (JSON)
  settings Json @default("{}")

  matchedAt DateTime  @default(now()) @map("matched_at")
  endedAt   DateTime? @map("ended_at")

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@map("dream_buddies")
}

model DreamCircle {
  id          String  @id @default(uuid())
  name        String
  description String  @db.Text
  category    String?

  createdBy  String  @map("created_by")
  maxMembers Int     @default(10) @map("max_members")
  isPublic   Boolean @default(true) @map("is_public")
  imageUrl   String? @map("image_url")

  rules Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members    CircleMember[]
  challenges CircleChallenge[]
  posts      CirclePost[]

  @@index([category])
  @@map("dream_circles")
}

model CircleMember {
  id       String      @id @default(uuid())
  circleId String      @map("circle_id")
  circle   DreamCircle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId   String      @map("user_id")
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  role String @default("member") // admin, member

  joinedAt DateTime  @default(now()) @map("joined_at")
  leftAt   DateTime? @map("left_at")

  @@unique([circleId, userId])
  @@index([userId])
  @@map("circle_members")
}

model CircleChallenge {
  id          String      @id @default(uuid())
  circleId    String      @map("circle_id")
  circle      DreamCircle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdBy   String      @map("created_by")

  title       String
  description String @db.Text

  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  targetType  String   @map("target_type")
  targetValue Int      @map("target_value")

  createdAt DateTime @default(now()) @map("created_at")

  participants ChallengeParticipant[]

  @@index([circleId, endDate])
  @@map("circle_challenges")
}

model ChallengeParticipant {
  id          String          @id @default(uuid())
  challengeId String          @map("challenge_id")
  challenge   CircleChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String          @map("user_id")

  status   String @default("in_progress") // in_progress, completed, failed
  progress Int    @default(0)

  joinedAt    DateTime  @default(now()) @map("joined_at")
  completedAt DateTime? @map("completed_at")

  @@unique([challengeId, userId])
  @@map("challenge_participants")
}

model CirclePost {
  id       String      @id @default(uuid())
  circleId String      @map("circle_id")
  circle   DreamCircle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId   String      @map("user_id")
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  content  String  @db.Text
  mediaUrl String? @map("media_url")

  type String @default("update") // update, achievement, question, tip

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  reactions CirclePostReaction[]

  @@index([circleId, createdAt])
  @@map("circle_posts")
}

model CirclePostReaction {
  id     String     @id @default(uuid())
  postId String     @map("post_id")
  post   CirclePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String     @map("user_id")
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  type String // like, celebrate, support, fire

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([postId, userId, type])
  @@map("circle_post_reactions")
}

model ActivityFeed {
  id      String @id @default(uuid())
  userId  String @map("user_id")
  user    User   @relation("UserFeed", fields: [userId], references: [id], onDelete: Cascade)
  actorId String @map("actor_id")
  actor   User   @relation("Actor", fields: [actorId], references: [id], onDelete: Cascade)

  activityType String @map("activity_type") // task_completed, milestone_reached, etc.

  // Activity data (JSON)
  content Json

  visibility String @default("friends") // public, friends, circles, private

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([actorId, createdAt])
  @@map("activity_feeds")
}

model PublicCommitment {
  id      String @id @default(uuid())
  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  dreamId String @map("dream_id")

  statement String   @db.Text
  deadline  DateTime

  status String @default("active") // active, completed, failed, cancelled

  shareSettings Json? @map("share_settings")
  witnessCount  Int   @default(0) @map("witness_count")

  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  witnesses CommitmentWitness[]

  @@index([userId])
  @@map("public_commitments")
}

model CommitmentWitness {
  id           String           @id @default(uuid())
  commitmentId String           @map("commitment_id")
  commitment   PublicCommitment @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
  userId       String?          @map("user_id")
  user         User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  email        String?
  name         String

  notifyOnProgress Boolean @default(true) @map("notify_on_progress")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([commitmentId, userId])
  @@unique([commitmentId, email])
  @@map("commitment_witnesses")
}
