{
  "name": "@dreamplanner/mobile",
  "version": "1.0.0",
  "description": "DreamPlanner Mobile App",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "android:build": "cd android && ./gradlew assembleRelease",
    "ios:build": "cd ios && xcodebuild -workspace DreamPlanner.xcworkspace -scheme DreamPlanner -configuration Release",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "react-native clean"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/native-stack": "^6.9.0",
    "@tanstack/react-query": "^5.17.0",
    "axios": "^1.6.0",
    "date-fns": "^3.2.0",
    "react": "18.2.0",
    "react-native": "0.73.2",
    "react-native-calendars": "^1.1304.0",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-mmkv": "^2.11.0",
    "react-native-paper": "^5.12.0",
    "react-native-reanimated": "^3.6.0",
    "react-native-safe-area-context": "^4.8.0",
    "react-native-screens": "^3.29.0",
    "react-native-vector-icons": "^10.0.0",
    "zustand": "^4.5.0",
    "@notifee/react-native": "^7.8.0",
    "@react-native-firebase/app": "^18.8.0",
    "@react-native-firebase/auth": "^18.8.0",
    "@react-native-firebase/messaging": "^18.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/runtime": "^7.23.0",
    "@react-native/babel-preset": "0.73.19",
    "@react-native/eslint-config": "0.73.2",
    "@react-native/metro-config": "0.73.3",
    "@react-native/typescript-config": "0.73.1",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "@types/react-native-vector-icons": "^6.4.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "0.77.0",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.3.0"
  }
}
