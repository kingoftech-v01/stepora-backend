#: apps/dreams/serializers.py:509
msgid "Title must be at least 3 characters long"
msgstr "يجب أن يكون العنوان 3 أحرف على الأقل"

#: apps/dreams/serializers.py:522
msgid "Description must be at least 10 characters long"
msgstr "يجب أن يكون الوصف 10 أحرف على الأقل"

#: apps/dreams/tasks.py:66
