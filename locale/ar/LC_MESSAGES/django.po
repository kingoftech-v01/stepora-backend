#: apps/conversations/views.py:373
msgid "No image file provided."
msgstr "لم يتم تقديم ملف صورة."

#: apps/conversations/views.py:377
msgid "Image too large. Max 20MB."
msgstr "الصورة كبيرة جداً. الحد الأقصى 20 ميجابايت."

#: apps/conversations/views.py:407
msgid "Invalid image URL."
msgstr "عنوان URL للصورة غير صالح."

#: apps/conversations/views.py:490 apps/conversations/views.py:512
#: apps/conversations/views.py:535
msgid "Message not found."
msgstr "الرسالة غير موجودة."

#: apps/conversations/views.py:539
msgid "emoji is required."
msgstr "emoji مطلوب."

#: apps/conversations/views.py:637
msgid "PDF export is not available. Install reportlab."
msgstr "تصدير PDF غير متاح. قم بتثبيت reportlab."

#: apps/conversations/views.py:753
msgid "callee_id is required."
msgstr "callee_id مطلوب."

#: apps/conversations/views.py:765
msgid "Cannot call yourself."
msgstr "لا يمكنك الاتصال بنفسك."

#: apps/conversations/views.py:770
msgid "Cannot call this user"
msgstr "لا يمكن الاتصال بهذا المستخدم"

#: apps/conversations/views.py:826 apps/conversations/views.py:851
#: apps/conversations/views.py:902 apps/conversations/views.py:926
#: apps/conversations/views.py:996
msgid "Call not found."
msgstr "المكالمة غير موجودة."

#: apps/conversations/views.py:829
msgid "Only the callee can accept."
msgstr "المتصل به فقط يمكنه القبول."

#: apps/conversations/views.py:832
#, python-format
msgid "Call is %(status)s, cannot accept."
msgstr "المكالمة %(status)s، لا يمكن القبول."

#: apps/conversations/views.py:854
msgid "Only the callee can reject."
msgstr "المتصل به فقط يمكنه الرفض."

#: apps/conversations/views.py:867
#, python-format
msgid "%(name)s declined your call"
