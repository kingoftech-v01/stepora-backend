#: apps/conversations/views.py:932
#, python-format
msgid "Call is %(status)s, cannot cancel."
msgstr "المكالمة %(status)s، لا يمكن الإلغاء."

#: apps/conversations/views.py:1041
#, python-format
msgid "Incoming %(call_type)s call"
msgstr "مكالمة %(call_type)s واردة"

#: apps/conversations/views.py:1042
#, python-format
msgid "%(name)s is calling you"
msgstr "%(name)s يتصل بك"

#: apps/dreams/serializers.py:497 apps/dreams/serializers.py:565
msgid "Target date must be at least 1 month from now."
msgstr "يجب أن يكون التاريخ المستهدف بعد شهر واحد على الأقل من الآن."

