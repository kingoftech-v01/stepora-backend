#, python-format
msgid "Message from %(name)s"
msgstr "%(name)s का संदेश"

#: apps/buddies/views.py:319 apps/buddies/views.py:697
#: apps/conversations/views.py:863 apps/notifications/tasks.py:526
msgid "Your buddy"
msgstr "आपका दोस्त"

#: apps/buddies/views.py:361 apps/buddies/views.py:647
#: apps/buddies/views.py:731
msgid "Active buddy pairing not found."
msgstr "सक्रिय बडी जोड़ी नहीं मिली।"

#: apps/buddies/views.py:367 apps/buddies/views.py:653
#: apps/buddies/views.py:737
msgid "You are not part of this pairing."
msgstr "आप इस जोड़ी का हिस्सा नहीं हैं।"

#: apps/buddies/views.py:426 apps/buddies/views.py:523
msgid "You already have an active buddy pairing."
msgstr "आपके पास पहले से एक सक्रिय बडी जोड़ी है।"

#: apps/buddies/views.py:516
msgid "You cannot pair with yourself."
msgstr "आप खुद से जोड़ी नहीं बना सकते।"

#: apps/buddies/views.py:531
msgid "Partner user not found."
msgstr "साथी उपयोगकर्ता नहीं मिला।"

#: apps/buddies/views.py:542
msgid "This user already has an active buddy pairing."
msgstr "इस उपयोगकर्ता के पास पहले से सक्रिय बडी जोड़ी है।"

#: apps/buddies/views.py:562
#, python-format
msgid "Buddy pairing created with %(name)s."
msgstr "%(name)s के साथ बडी जोड़ी बनाई गई।"

#: apps/buddies/views.py:562 apps/social/views.py:367
msgid "user"
msgstr "उपयोगकर्ता"

#: apps/buddies/views.py:587 apps/buddies/views.py:615
msgid "Pending buddy pairing not found."
msgstr "लंबित बडी जोड़ी नहीं मिली।"

#: apps/buddies/views.py:594
msgid "Buddy pairing accepted."
msgstr "बडी जोड़ी स्वीकृत।"

#: apps/buddies/views.py:623
msgid "Buddy pairing rejected."
msgstr "बडी जोड़ी अस्वीकृत।"

#: apps/buddies/views.py:695
msgid "Buddy Encouragement"
msgstr "बडी प्रोत्साहन"

#: apps/buddies/views.py:697
#, python-format
msgid "%(name)s sent you encouragement!"
msgstr "%(name)s ने आपको प्रोत्साहन भेजा!"

#: apps/buddies/views.py:707
#, python-format
msgid "Encouragement sent to %(name)s."
msgstr "%(name)s को प्रोत्साहन भेजा गया।"

#: apps/buddies/views.py:745
msgid "Buddy pairing ended."
msgstr "बडी जोड़ी समाप्त।"

#: apps/calendar/serializers.py:93 apps/calendar/serializers.py:106
#: apps/calendar/serializers.py:150
msgid "End time must be after start time"
msgstr "समाप्ति समय प्रारंभ समय के बाद होना चाहिए"

#: apps/calendar/serializers.py:154
msgid "Day of week must be between 0 (Monday) and 6 (Sunday)"
msgstr "सप्ताह का दिन 0 (सोमवार) और 6 (रविवार) के बीच होना चाहिए"

#: apps/calendar/views.py:106 apps/calendar/views.py:120
msgid "This event conflicts with existing events."
msgstr "यह कार्यक्रम मौजूदा कार्यक्रमों से टकराता है।"

#: apps/calendar/views.py:108 apps/calendar/views.py:122
#: apps/calendar/views.py:157
msgid "Set force=true to save anyway."
msgstr "फिर भी सहेजने के लिए force=true सेट करें।"

#: apps/calendar/views.py:155
msgid "This time conflicts with existing events."
msgstr "यह समय मौजूदा कार्यक्रमों से टकराता है।"

#: apps/calendar/views.py:230
msgid "start and end dates required (ISO format)"
msgstr "प्रारंभ और समाप्ति तिथियाँ आवश्यक हैं (ISO प्रारूप)"

#: apps/calendar/views.py:239
msgid "Invalid date format. Use ISO format (YYYY-MM-DDTHH:MM:SS)"
msgstr "अमान्य तिथि प्रारूप। ISO प्रारूप का उपयोग करें (YYYY-MM-DDTHH:MM:SS)"

#: apps/calendar/views.py:307
msgid "task_id and new_date required"
msgstr "task_id और new_date आवश्यक हैं"

#: apps/calendar/views.py:321
msgid "Task rescheduled successfully"
msgstr "कार्य सफलतापूर्वक पुनर्निर्धारित"

#: apps/calendar/views.py:328
msgid "Task not found"
msgstr "कार्य नहीं मिला"

#: apps/calendar/views.py:333
msgid "Invalid date format"
msgstr "अमान्य तिथि प्रारूप"

#: apps/calendar/views.py:355
msgid "date and duration_mins are required"
msgstr "date और duration_mins आवश्यक हैं"

#: apps/calendar/views.py:364
msgid "Invalid date or duration format"
msgstr "अमान्य तिथि या अवधि प्रारूप"

#: apps/calendar/views.py:370
msgid "Duration must be between 5 and 480 minutes"
msgstr "अवधि 5 से 480 मिनट के बीच होनी चाहिए"

#: apps/calendar/views.py:515
msgid "Google Calendar integration is not configured."
msgstr "Google कैलेंडर एकीकरण कॉन्फ़िगर नहीं है।"

#: apps/calendar/views.py:554
msgid "Authorization code is required."
msgstr "प्राधिकरण कोड आवश्यक है।"

#: apps/calendar/views.py:565
#, python-format
msgid "Token exchange failed: %(error)s"
msgstr "टोकन विनिमय विफल: %(error)s"

#: apps/calendar/views.py:609
msgid "Google Calendar not connected."
msgstr "Google कैलेंडर कनेक्ट नहीं है।"

#: apps/calendar/views.py:636
msgid "No integration found."
msgstr "कोई एकीकरण नहीं मिला।"

#: apps/calendar/views.py:663
msgid "Feed not found."
msgstr "फ़ीड नहीं मिला।"

#: apps/calendar/views.py:731
msgid "Missing authorization code."
msgstr "प्राधिकरण कोड गायब है।"

#: apps/circles/serializers.py:291 apps/circles/serializers.py:425
#: apps/circles/serializers.py:458 apps/circles/views.py:929
#: apps/circles/views.py:1021
msgid "Anonymous"
msgstr "अनाम"

#: apps/circles/views.py:210 apps/circles/views.py:1449
msgid "You are already a member of this circle."
msgstr "आप पहले से इस सर्कल के सदस्य हैं।"

#: apps/circles/views.py:217 apps/circles/views.py:1455
msgid "This circle has reached its maximum number of members."
msgstr "इस सर्कल ने अधिकतम सदस्य संख्या प्राप्त कर ली है।"

#: apps/circles/views.py:224
msgid "This circle is private. You need an invitation to join."
msgstr "यह सर्कल निजी है। शामिल होने के लिए आमंत्रण चाहिए।"

#: apps/circles/views.py:235 apps/circles/views.py:1471
#, python-format
msgid "Successfully joined %(name)s."
msgstr "%(name)s में सफलतापूर्वक शामिल हुए।"

#: apps/circles/views.py:268
msgid "You are not a member of this circle."
msgstr "आप इस सर्कल के सदस्य नहीं हैं।"

#: apps/circles/views.py:303
#, python-format
msgid "Successfully left %(name)s."
msgstr "%(name)s से सफलतापूर्वक बाहर निकले।"

#: apps/circles/views.py:328
msgid "You must be a member to view the feed."
msgstr "फ़ीड देखने के लिए आपको सदस्य होना चाहिए।"

#: apps/circles/views.py:368
msgid "You must be a member to post."
msgstr "पोस्ट करने के लिए आपको सदस्य होना चाहिए।"

#: apps/circles/views.py:429
msgid "Only admins can update this circle."
msgstr "केवल व्यवस्थापक इस सर्कल को अपडेट कर सकते हैं।"

#: apps/circles/views.py:460
msgid "Only admins can delete this circle."
msgstr "केवल व्यवस्थापक इस सर्कल को हटा सकते हैं।"

#: apps/circles/views.py:486 apps/circles/views.py:524
#: apps/circles/views.py:565 apps/circles/views.py:598
msgid "Post not found."
msgstr "पोस्ट नहीं मिली।"

#: apps/circles/views.py:494
msgid "You do not have permission to edit this post."
msgstr "आपको इस पोस्ट को संपादित करने की अनुमति नहीं है।"

#: apps/circles/views.py:531
msgid "You do not have permission to delete this post."
msgstr "आपको इस पोस्ट को हटाने की अनुमति नहीं है।"

#: apps/circles/views.py:558
msgid "You must be a member to react."
msgstr "प्रतिक्रिया देने के लिए सदस्य होना चाहिए।"

#: apps/circles/views.py:577
msgid "Reaction added."
msgstr "प्रतिक्रिया जोड़ी गई।"

#: apps/circles/views.py:578
msgid "Reaction updated."
msgstr "प्रतिक्रिया अपडेट की गई।"

#: apps/circles/views.py:605
msgid "No reaction found."
msgstr "कोई प्रतिक्रिया नहीं मिली।"

#: apps/circles/views.py:607
msgid "Reaction removed."
msgstr "प्रतिक्रिया हटाई गई।"

#: apps/circles/views.py:628
msgid "Only admins can promote members."
msgstr "केवल व्यवस्थापक सदस्यों को पदोन्नत कर सकते हैं।"

#: apps/circles/views.py:635 apps/circles/views.py:673
#: apps/circles/views.py:710
msgid "Member not found."
msgstr "सदस्य नहीं मिला।"

#: apps/circles/views.py:639
msgid "Cannot change an admin role."
msgstr "व्यवस्थापक की भूमिका नहीं बदल सकते।"

#: apps/circles/views.py:646
#, python-format
msgid "%(name)s promoted to moderator."
msgstr "%(name)s को मॉडरेटर के रूप में पदोन्नत किया गया।"

#: apps/circles/views.py:646 apps/circles/views.py:684
msgid "User"
msgstr "उपयोगकर्ता"

#: apps/circles/views.py:666
msgid "Only admins can demote members."
msgstr "केवल व्यवस्थापक सदस्यों को पदावनत कर सकते हैं।"

#: apps/circles/views.py:677
msgid "Only moderators can be demoted."
msgstr "केवल मॉडरेटर पदावनत किए जा सकते हैं।"

#: apps/circles/views.py:684
#, python-format
msgid "%(name)s demoted to member."
msgstr "%(name)s को सदस्य के रूप में पदावनत किया गया।"

#: apps/circles/views.py:703
msgid "Only admins and moderators can remove members."
msgstr "केवल व्यवस्थापक और मॉडरेटर सदस्यों को हटा सकते हैं।"

#: apps/circles/views.py:714
msgid "Cannot remove an admin."
msgstr "व्यवस्थापक को नहीं हटा सकते।"

#: apps/circles/views.py:719
msgid "Member removed from circle."
msgstr "सदस्य को सर्कल से हटाया गया।"

#: apps/circles/views.py:740
msgid "Only admins and moderators can invite users."
msgstr "केवल व्यवस्थापक और मॉडरेटर उपयोगकर्ताओं को आमंत्रित कर सकते हैं।"

#: apps/circles/views.py:756
msgid "User is already a member of this circle."
msgstr "उपयोगकर्ता पहले से इस सर्कल का सदस्य है।"

#: apps/circles/views.py:765
msgid "An invitation is already pending for this user."
msgstr "इस उपयोगकर्ता के लिए एक आमंत्रण पहले से लंबित है।"

#: apps/circles/views.py:799
msgid "Only admins and moderators can generate invite links."
msgstr "केवल व्यवस्थापक और मॉडरेटर आमंत्रण लिंक बना सकते हैं।"

#: apps/circles/views.py:833
msgid "Only admins and moderators can view invitations."
msgstr "केवल व्यवस्थापक और मॉडरेटर आमंत्रण देख सकते हैं।"

#: apps/circles/views.py:864
msgid "You must be a member of the circle."
msgstr "आपको सर्कल का सदस्य होना चाहिए।"

#: apps/circles/views.py:871 apps/circles/views.py:912
msgid "Challenge not found."
msgstr "चुनौती नहीं मिली।"

#: apps/circles/views.py:875
msgid "You must join the challenge first."
msgstr "पहले चुनौती में शामिल होना होगा।"

#: apps/circles/views.py:955
msgid "You must be a member to view chat."
msgstr "चैट देखने के लिए सदस्य होना चाहिए।"

#: apps/circles/views.py:996
msgid "You must be a member to send messages."
msgstr "संदेश भेजने के लिए सदस्य होना चाहिए।"

#: apps/circles/views.py:1003
msgid "Content is required."
msgstr "सामग्री आवश्यक है।"

#: apps/circles/views.py:1058
msgid "You must be a member to start a call."
msgstr "कॉल शुरू करने के लिए सदस्य होना चाहिए।"

#: apps/circles/views.py:1066
msgid "A call is already active in this circle."
msgstr "इस सर्कल में पहले से एक कॉल सक्रिय है।"

#: apps/circles/views.py:1073 apps/conversations/views.py:756
msgid "call_type must be voice or video."
msgstr "call_type voice या video होना चाहिए।"

#: apps/circles/views.py:1107 apps/circles/views.py:1322
#: apps/conversations/views.py:1027 apps/dreams/views.py:980
#: apps/notifications/tasks.py:510 apps/social/views.py:1542
#: apps/social/views.py:1596 apps/social/views.py:1670
msgid "Someone"
msgstr "कोई"

#: apps/circles/views.py:1137
msgid "You must be a member."
msgstr "आपको सदस्य होना चाहिए।"

#: apps/circles/views.py:1144
msgid "No active call in this circle."
msgstr "इस सर्कल में कोई सक्रिय कॉल नहीं।"

#: apps/circles/views.py:1180 apps/circles/views.py:1227
msgid "No active call."
msgstr "कोई सक्रिय कॉल नहीं।"

#: apps/circles/views.py:1190
msgid "You are not in this call."
msgstr "आप इस कॉल में नहीं हैं।"

#: apps/circles/views.py:1235
msgid "Only the initiator or an admin can end the call."
msgstr "केवल आरंभकर्ता या व्यवस्थापक कॉल समाप्त कर सकते हैं।"

#: apps/circles/views.py:1328
#, python-format
msgid "%(name)s started a %(type)s call"
msgstr "%(name)s ने %(type)s कॉल शुरू किया"

#: apps/circles/views.py:1329
#, python-format
msgid "Join the call in %(circle)s"
msgstr "%(circle)s में कॉल में शामिल हों"

#: apps/circles/views.py:1381
msgid "You must be a member of the circle to join this challenge."
msgstr "इस चुनौती में शामिल होने के लिए सर्कल का सदस्य होना चाहिए।"

#: apps/circles/views.py:1388
msgid "You have already joined this challenge."
msgstr "आप पहले से इस चुनौती में शामिल हैं।"

#: apps/circles/views.py:1395
#, python-format
msgid "Successfully joined challenge: %(title)s."
msgstr "चुनौती में सफलतापूर्वक शामिल हुए: %(title)s।"

#: apps/circles/views.py:1426
msgid "Invalid or expired invite code."
msgstr "अमान्य या समाप्त आमंत्रण कोड।"

#: apps/circles/views.py:1434
msgid "This invitation has expired."
msgstr "यह आमंत्रण समाप्त हो गया है।"

#: apps/circles/views.py:1443
msgid "This invitation is for another user."
msgstr "यह आमंत्रण किसी अन्य उपयोगकर्ता के लिए है।"

#: apps/conversations/serializers.py:49
msgid "Message content cannot be empty"
msgstr "संदेश सामग्री खाली नहीं हो सकती"

#: apps/conversations/serializers.py:184
#, python-format
msgid "Invalid conversation type. Must be one of: %(types)s"
msgstr "अमान्य बातचीत प्रकार। इनमें से एक होना चाहिए: %(types)s"

#: apps/conversations/serializers.py:195
#, python-format
msgid ""
"Conversations of type '%(type)s' must be linked to a dream. Please provide a "
"dream ID."
msgstr "'%(type)s' प्रकार की बातचीत एक सपने से जुड़ी होनी चाहिए। कृपया सपना ID प्रदान करें।"

#: apps/conversations/views.py:270
#, python-format
msgid "AI produced an invalid response: %(message)s"
msgstr "AI ने एक अमान्य प्रतिक्रिया उत्पन्न की: %(message)s"

#: apps/conversations/views.py:300
msgid "No audio file provided."
msgstr "कोई ऑडियो फ़ाइल प्रदान नहीं की गई।"

#: apps/conversations/views.py:304
msgid "Audio file too large. Max 25MB."
msgstr "ऑडियो फ़ाइल बहुत बड़ी है। अधिकतम 25MB।"

#: apps/conversations/views.py:315
#, python-format
msgid ""
"Unsupported audio format: %(format)s. Allowed: mp3, m4a, wav, webm, ogg, "
"flac, aac."
msgstr "असमर्थित ऑडियो प्रारूप: %(format)s। अनुमत: mp3, m4a, wav, webm, ogg, flac, aac।"

