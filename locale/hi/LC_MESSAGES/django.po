#: apps/buddies/tasks.py:57
msgid "Check in with your buddy!"
msgstr "अपने दोस्त से संपर्क करें!"

#: apps/buddies/tasks.py:58
#, python-format
msgid ""
"It's been a while since you encouraged %(name)s. Send them some motivation!"
msgstr "%(name)s को प्रोत्साहित किए कुछ समय हो गया। उन्हें कुछ प्रेरणा भेजें!"

#: apps/buddies/tasks.py:60 apps/buddies/views.py:707
msgid "your buddy"
