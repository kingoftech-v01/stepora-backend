msgid "You must be a member to view the feed."
msgstr "피드를 보려면 멤버여야 합니다."

#: apps/circles/views.py:368
msgid "You must be a member to post."
msgstr "게시하려면 멤버여야 합니다."

#: apps/circles/views.py:429
msgid "Only admins can update this circle."
msgstr "관리자만 이 서클을 업데이트할 수 있습니다."

#: apps/circles/views.py:460
msgid "Only admins can delete this circle."
msgstr "관리자만 이 서클을 삭제할 수 있습니다."

#: apps/circles/views.py:486 apps/circles/views.py:524
#: apps/circles/views.py:565 apps/circles/views.py:598
msgid "Post not found."
msgstr "게시물을 찾을 수 없습니다."

