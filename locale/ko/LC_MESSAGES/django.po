msgstr "%(name)s이(가) %(type)s 통화를 시작했습니다"

#: apps/circles/views.py:1329
#, python-format
msgid "Join the call in %(circle)s"
msgstr "%(circle)s의 통화에 참여하세요"

#: apps/circles/views.py:1381
msgid "You must be a member of the circle to join this challenge."
msgstr "이 챌린지에 참여하려면 서클의 멤버여야 합니다."

#: apps/circles/views.py:1388
msgid "You have already joined this challenge."
msgstr "이미 이 챌린지에 참여했습니다."

#: apps/circles/views.py:1395
#, python-format
msgid "Successfully joined challenge: %(title)s."
msgstr "챌린지에 성공적으로 참여했습니다: %(title)s."

#: apps/circles/views.py:1426
msgid "Invalid or expired invite code."
msgstr "유효하지 않거나 만료된 초대 코드입니다."

#: apps/circles/views.py:1434
msgid "This invitation has expired."
msgstr "이 초대가 만료되었습니다."

#: apps/circles/views.py:1443
msgid "This invitation is for another user."
msgstr "이 초대는 다른 사용자를 위한 것입니다."

#: apps/conversations/serializers.py:49
msgid "Message content cannot be empty"
msgstr "메시지 내용이 비어 있을 수 없습니다"

#: apps/conversations/serializers.py:184
#, python-format
msgid "Invalid conversation type. Must be one of: %(types)s"
msgstr "유효하지 않은 대화 유형입니다. 다음 중 하나여야 합니다: %(types)s"

#: apps/conversations/serializers.py:195
#, python-format
msgid ""
"Conversations of type '%(type)s' must be linked to a dream. Please provide a "
"dream ID."
msgstr "'%(type)s' 유형의 대화는 꿈에 연결되어야 합니다. 꿈 ID를 제공해 주세요."

#: apps/conversations/views.py:270
#, python-format
msgid "AI produced an invalid response: %(message)s"
msgstr "AI가 유효하지 않은 응답을 생성했습니다: %(message)s"

#: apps/conversations/views.py:300
msgid "No audio file provided."
msgstr "오디오 파일이 제공되지 않았습니다."

#: apps/conversations/views.py:304
msgid "Audio file too large. Max 25MB."
msgstr "오디오 파일이 너무 큽니다. 최대 25MB입니다."

#: apps/conversations/views.py:315
#, python-format
msgid ""
"Unsupported audio format: %(format)s. Allowed: mp3, m4a, wav, webm, ogg, "
"flac, aac."
msgstr "지원되지 않는 오디오 형식: %(format)s. 허용: mp3, m4a, wav, webm, ogg, flac, aac."

#: apps/conversations/views.py:373
msgid "No image file provided."
msgstr "이미지 파일이 제공되지 않았습니다."

#: apps/conversations/views.py:377
msgid "Image too large. Max 20MB."
msgstr "이미지가 너무 큽니다. 최대 20MB입니다."

#: apps/conversations/views.py:407
msgid "Invalid image URL."
msgstr "유효하지 않은 이미지 URL입니다."

#: apps/conversations/views.py:490 apps/conversations/views.py:512
#: apps/conversations/views.py:535
msgid "Message not found."
msgstr "메시지를 찾을 수 없습니다."

#: apps/conversations/views.py:539
msgid "emoji is required."
msgstr "emoji가 필요합니다."

#: apps/conversations/views.py:637
msgid "PDF export is not available. Install reportlab."
msgstr "PDF 내보내기를 사용할 수 없습니다. reportlab을 설치하세요."

#: apps/conversations/views.py:753
msgid "callee_id is required."
msgstr "callee_id가 필요합니다."

#: apps/conversations/views.py:765
msgid "Cannot call yourself."
msgstr "자기 자신에게 전화할 수 없습니다."

#: apps/conversations/views.py:770
msgid "Cannot call this user"
msgstr "이 사용자에게 전화할 수 없습니다"

#: apps/conversations/views.py:826 apps/conversations/views.py:851
