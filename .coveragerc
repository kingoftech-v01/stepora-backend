[run]
source = apps,core,integrations
omit =
    */migrations/*
    */tests/*
    */tests.py
    */test_*.py
    */tests_*.py
    */conftest.py
    */__pycache__/*
    */venv/*
    */env/*
    manage.py
    config/settings/*
    config/wsgi.py
    config/asgi.py

[report]
precision = 2
show_missing = True
skip_covered = False

exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    raise NotImplementedError
    @abstract
    pass$
